# Instance configuration
AGENT_NAME=pi-sandbox

# Resources
CPU_LIMIT=2
MEMORY_LIMIT=4g
PIDS_LIMIT=100

# Network (bridge = internet access for AI agents)
NETWORK_MODE=bridge

# Volumes (absolute paths on host)
MEMORY_VOLUME=${HOME}/pi-sandbox/memory
PROJECT_VOLUME=${HOME}/pi-sandbox/projects

# Security
READ_ONLY=true

# Note: API keys should be managed via varlock, not this file
