# Instance configuration
AGENT_NAME=pi-sandbox
AGENT_VERSION=latest

# Resources
CPU_LIMIT=2
MEMORY_LIMIT=4g

# Network (none = fully isolated, bridge = internet access)
NETWORK_MODE=none

# Volumes (absolute paths on host)
MEMORY_VOLUME=${HOME}/pi-sandbox/memory
PROJECT_VOLUME=${HOME}/pi-sandbox/projects

# Security
PIDS_LIMIT=100
READ_ONLY=false
